---
import WidgetWrapper from '../ui/WidgetWrapper.astro';
import Image from '~/components/common/Image.astro';
import photo from '~/assets/images/clement-latzarus.jpeg';

interface Props {
  id?: string;
  isDark?: boolean;
}

const { id, isDark = false } = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass="max-w-4xl mx-auto">
  <div class="text-center mb-10">
    <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">Derrière Biblys</p>
  </div>

  <div class="flex flex-col md:flex-row gap-10 items-center">
    <div class="flex flex-col items-center md:items-end gap-3 md:w-1/3">
      <Image
        src={photo}
        alt="Clément Latzarus, créateur de Biblys"
        class="rounded-full w-40 h-40 object-cover object-top shadow-md"
        width={160}
        height={160}
      />
      <div class="text-center">
        <h2 class="text-xl font-bold font-heading">Clément Latzarus</h2>
        <p class="text-sm text-muted dark:text-slate-400">Créateur de Biblys</p>
      </div>
    </div>

    <div class="md:w-2/3 flex flex-col gap-6">
      <div>
        <p class="text-muted dark:text-slate-400 text-lg leading-relaxed mb-4">
          Ancien libraire spécialiste e-commerce, ancien responsable web et numérique des <a
            href="https://www.belial.fr/"
            class="text-primary hover:underline">Éditions du Bélial'</a
          >, reconverti dans le développement web depuis près de 20 ans, j'ai créé Biblys en 2008.
        </p>
        <p class="text-muted dark:text-slate-400 text-lg leading-relaxed">
          Aujourd'hui lead developer web pour le service public <a
            href="https://pix.fr/"
            class="text-primary hover:underline">Pix</a
          >, je continue à accompagner une quinzaine de maisons d'édition et de librairies indépendantes sur le web au
          quotidien.
        </p>
      </div>
    </div>
  </div>

  <div class="flex justify-center flex-wrap gap-4 mt-10">
    <a href="/contact" class="btn-primary">Me contacter</a>
    <a href="https://cal.com/clemlatz/rdv" class="btn-secondary" target="_blank" rel="noopener noreferrer"
      >Prendre rendez-vous</a
    >
  </div>
</WidgetWrapper>
