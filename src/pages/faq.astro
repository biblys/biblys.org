---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Questions fréquentes',
  description:
    'Trouvez les réponses aux questions que vous vous posez sur Biblys : fonctionnalités, prise en main, tarifs et accompagnement.',
};

const entries = await getCollection('faq');
entries.sort((a, b) => a.id.localeCompare(b.id));

function toHtml(body: string): string {
  return body
    .trim()
    .split(/\n\n+/)
    .map((p) => `<p>${p.replace(/\n/g, ' ').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`)
    .join('');
}

const items = entries.map((entry) => ({
  title: entry.data.title,
  description: toHtml(entry.body ?? ''),
}));
---

<Layout metadata={metadata}>
  <FAQs title="Questions fréquentes" classes={{ container: 'max-w-6xl' }} items={items} />

  <CallToAction
    title="Prêt·e à vous lancer ?"
    actions={[
      {
        variant: 'primary',
        text: 'Commencer',
        href: '/commencer',
      },
    ]}
  />
</Layout>
