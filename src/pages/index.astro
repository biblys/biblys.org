---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import AuthorBio from '~/components/widgets/AuthorBio.astro';

const metadata = {
  title: 'Biblys · Le logiciel libre pour créer des boutiques de livre en ligne.',
  ignoreTitleTemplate: true,
};

const softwareApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Biblys',
  url: 'https://biblys.org',
  description:
    "Logiciel libre de vente de livres en ligne pour les maisons d'édition et librairies indépendantes. Gestion du catalogue, boutique en ligne, livres numériques, commandes et expédition.",
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  inLanguage: 'fr',
  offers: [
    { '@type': 'Offer', name: 'Version open source', price: '0', priceCurrency: 'EUR' },
    {
      '@type': 'Offer',
      name: 'Version accompagnée — Palier 1',
      price: '20',
      priceCurrency: 'EUR',
      billingIncrement: 1,
      unitText: 'mois',
    },
    {
      '@type': 'Offer',
      name: 'Version accompagnée — Palier 2',
      price: '35',
      priceCurrency: 'EUR',
      billingIncrement: 1,
      unitText: 'mois',
    },
    {
      '@type': 'Offer',
      name: 'Version accompagnée — Palier 3',
      price: '50',
      priceCurrency: 'EUR',
      billingIncrement: 1,
      unitText: 'mois',
    },
    {
      '@type': 'Offer',
      name: 'Version accompagnée — Palier 4',
      price: '100',
      priceCurrency: 'EUR',
      billingIncrement: 1,
      unitText: 'mois',
    },
  ],
  featureList: [
    'Gestion de catalogue bibliographique',
    'Boutique en ligne avec rayons et mots-clés',
    'Vente de livres numériques avec téléchargement sécurisé',
    "Gestion des commandes et de l'expédition",
    'Gestion du stock et des fournisseurs',
    'Paiement sécurisé Stripe et PayPlug',
    'Blog et calendrier éditorial',
    'Financement participatif intégré',
    'Code source ouvert (AGPL-3.0)',
  ],
  codeRepository: 'https://github.com/biblys/biblys',
  license: 'https://www.gnu.org/licenses/agpl-3.0.html',
  author: {
    '@type': 'Person',
    name: 'Clément Latzarus',
    url: 'https://clemlatz.dev',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
  </Fragment>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Commencer',
        href: '/commencer',
      },
    ]}
    image={{
      src: '~/assets/images/hero-image.jpg',
      alt: 'Photographie d’une librairie montrant une libraire en train d’encaisser',
    }}
    imageCaption={`Photo de <a href="https://unsplash.com/fr/@paulinel?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Pauline Loroy</a> sur <a href="https://unsplash.com/fr/photos/personnes-a-linterieur-de-la-bibliotheque-tv8PIPPY3rQ?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText">Unsplash</a>`}
  >
    <Fragment slot="title">
      Le logiciel <span class="text-accent highlight">libre</span>
      pour créer des <span class="text-accent highlight">boutiques de livres</span> en ligne
    </Fragment>

    <Fragment slot="subtitle">
      L'outil e-commerce pour les maisons d'édition et librairies indépendantes. Gratuit, sans commission sur vos
      ventes, et sans aucune compétence technique requise.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="fonctionnalites"
    tagline="Fonctionnalités"
    title="Ce que Biblys peut faire pour vous"
    subtitle="Tout pour vendre des livres papiers et numériques sur le web."
    columns={3}
    items={[
      {
        title: 'Catalogue',
        description:
          'Gérez un catalogue avec des informations bibliographiques détaillées, des pages auteur·ices avec biographie, des collections.',
        icon: 'tabler:books',
      },
      {
        title: 'Boutique en ligne',
        description: 'Organisez votre boutique en ligne comme vous l’entendez avec des rayons et des mots-clés.',
        icon: 'tabler:building-store',
      },
      {
        title: 'Vente par correspondance',
        description: 'Gérez vos commandes, y compris l’expédition, le suivi et la relance.',
        icon: 'tabler:cube-send',
      },
      {
        title: 'Gestion du stock',
        description: 'Gérez votre stock, les fournisseurs, les réassorts, les retours et les inventaires.',
        icon: 'tabler:packages',
      },
      {
        title: 'Livres numériques',
        description:
          'Vendez des livres numériques ou audio avec téléchargement sécurisé et protection par tatouage numérique facultative.',
        icon: 'tabler:notebook',
      },
      {
        title: 'Paiement sécurisé',
        description:
          'Proposez le paiement sécurisé avec Stripe ou PayPlug, en plus du paiement par chèque ou virement.',
        icon: 'tabler:brand-mastercard',
      },
      {
        title: 'Contenu éditorial',
        description: 'Communiquez avec vos lecteur·ices grâce à un blog et un calendrier connecté à votre catalogue.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Crowdfunding',
        description: 'Impliquez votre communauté grâce à la plateforme de financement participatif intégrée.',
        icon: 'tabler:coins',
      },
      {
        title: 'Open source',
        description:
          'Une fonctionnalité vous manque ? Ne répond pas parfaitement à votre besoin ? Tout le monde peut améliorer Biblys en contribuant à son code source.',
        icon: 'tabler:brand-git',
      },
      {
        title: 'Et bien plus encore !',
        description:
          'Organisez des opérations commerciales, envoyez des services de presse numériques, permettez à vos lecteur·ices de créer des listes de souhaits, d’être alerté de la réimpression d’un livre, etc.',
        icon: 'tabler:gift',
      },
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Créez très rapidement votre site grâce à Biblys !"
    items={[
      {
        title: 'Étape 1 : <span class="font-medium">Installer</span>',
        description: 'Installez facilement Biblys chez votre hébergeur grâce à un tutoriel détaillé.',
        icon: 'tabler:package',
      },
      {
        title: 'Étape 2 : <span class="font-medium">Référencer</span>',
        description: 'Ajoutez des livres au catalogue de votre site.',
        icon: 'tabler:letter-case',
      },
      {
        title: 'Étape 3 : <span class="font-medium">Personnaliser (facultatif)</span>',
        description:
          'Personnaliser l’apparence de votre site grâce à l’éditeur de thème intégré ou démarrez sans attendre en utilisant l’habillage de base livré avec Biblys.',
        icon: 'tabler:paint',
      },
      {
        title: 'Votre site est prêt !',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: "Capture d'écran de l'interface d'administration Biblys",
    }}
  />

  <Features2
    title="Elles font confiance à Biblys"
    subtitle="Les maisons d’édition et librairies qui utilisent Biblys aujourd’hui"
    items={[
      {
        title: 'Éditions du Bélial’',
        websiteUrl: 'https://www.belial.fr/',
        description: 'Le Bélial’ utilise Biblys depuis 2009 pour vendre des livres papiers et numériques.',
      },
      {
        title: 'Librairie L’Atalante',
        websiteUrl: 'https://librairielatalante.com/',
        description:
          'La librairie nantaise vend ses livres par correspondance tout en proposant de les retirer en magasin.',
      },
      {
        title: 'Éditions ActuSF',
        websiteUrl: 'https://www.editions-actusf.fr/',
        description: 'ActuSF vend ses livres papier et numériques sur le web grâce à Biblys depuis 2011.',
      },
      {
        title: 'Librairie Scylla',
        websiteUrl: 'https://www.scylla.fr/',
      },
      {
        title: 'Éditions Scylla',
        websiteUrl: 'https://editions.scylla.fr/',
      },
      {
        title: 'Flatland',
        websiteUrl: 'https://www.flatland-editeur.fr/',
      },
      {
        title: 'Éditions Dystopia',
        websiteUrl: 'https://www.dystopia.fr/',
      },
      {
        title: 'Librairie du Voyageur',
        websiteUrl: 'https://legacy.biblys.net//blog/la-librairie-du-voyageur-propulsee-par-biblys',
      },
      {
        title: 'Aux forges de Vulcain',
        websiteUrl: 'https://www.auxforgesdevulcain.fr/',
      },
      {
        title: 'Éditions Musidora',
        websiteUrl: 'https://leseditionsmusidora.com/',
      },
      {
        title: 'Librairie Alterlibris',
        websiteUrl: 'https://alterlibris.fr/',
      },
      {
        title: 'Librairie Charybde',
        websiteUrl: 'https://www.charybde.fr/',
      },
      {
        title: 'Librairie Zalem',
        websiteUrl: 'https://www.librairie-zalem.fr/',
      },
      {
        title: 'Éditions Le Baiser du frelon',
        websiteUrl: 'https://lebaiserdufrelon.fr/',
      },
      {
        title: 'Éditions Velvet',
        websiteUrl: 'https://www.editionsvelvet.com/',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- AuthorBio Widget ************** -->

  <AuthorBio id="auteur" />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Prêt·e à vous lancer ?"
    actions={[
      {
        variant: 'primary',
        text: 'Commencer',
        href: '/commencer',
      },
    ]}
  />
</Layout>
